// ============================================
// RESTAURANT OS - Production PostgreSQL Schema
// Africa-First, Global-Ready
// ============================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl  = env("DATABASE_URL_DIRECT")
}

// ============================================
// CORE - Users & Authentication
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  role          UserRole  @default(CUSTOMER)
  
  // Profile
  firstName     String?
  lastName      String?
  avatar        String?
  language      String    @default("fr")
  timezone      String    @default("Africa/Abidjan")
  
  // Verification
  emailVerified DateTime?
  phoneVerified DateTime?
  
  // Status
  isActive      Boolean   @default(true)
  isLocked      Boolean   @default(false)
  lockedAt      DateTime?
  lastLoginAt   DateTime?
  lastLoginIp   String?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  // Relations
  sessions      Session[]
  otpCodes      OtpCode[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  organizationUsers OrganizationUser[]
  
  // Polymorphic relations
  customerProfiles  CustomerProfile[]
  staffProfiles     StaffProfile[]
  driverProfile     Driver?
  
  @@index([email])
  @@index([phone])
  @@index([role])
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  ORG_MANAGER
  RESTAURANT_ADMIN
  RESTAURANT_MANAGER
  STAFF
  KITCHEN
  DRIVER
  CUSTOMER
  SUPPORT
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

model OtpCode {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone        String?
  email        String?
  code         String
  type         OtpType
  attempts     Int      @default(0)
  
  verifiedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([phone, type])
  @@index([email, type])
}

enum OtpType {
  LOGIN
  REGISTER
  VERIFY_PHONE
  VERIFY_EMAIL
  RESET_PASSWORD
  VERIFY_PAYMENT
}

// ============================================
// ORGANIZATION - Multi-tenant
// ============================================

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logo            String?
  description     String?
  website         String?
  
  // Contact
  email           String
  phone           String
  address         String?
  city            String
  countryId       String
  country         Country  @relation(fields: [countryId], references: [id])
  
  // Business
  taxId           String?
  businessType    String?
  currencyId      String
  currency        Currency @relation(fields: [currencyId], references: [id])
  
  // Subscription
  plan            Plan     @default(STARTER)
  planExpiresAt   DateTime?
  stripeCustomerId String?
  
  // Settings
  settings        OrganizationSettings?
  isActive        Boolean  @default(true)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  users           OrganizationUser[]
  brands          Brand[]
  restaurants     Restaurant[]
  
  @@index([slug])
  @@index([countryId])
}

enum Plan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

model OrganizationSettings {
  id               String   @id @default(cuid())
  organizationId   String   @unique
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Orders
  minOrderAmount   Float    @default(0)
  maxDeliveryRadius Float   @default(10)
  defaultDeliveryFee Float  @default(0)
  autoAcceptOrders Boolean  @default(false)
  orderPrepTime    Int      @default(15)
  
  // Reservations
  reservationEnabled Boolean @default(true)
  autoConfirmReservations Boolean @default(true)
  defaultTableTime Int      @default(120)
  noShowFee        Float    @default(0)
  noShowBuffer     Int      @default(15)
  
  // Payments
  acceptsCash      Boolean  @default(true)
  acceptsMobileMoney Boolean @default(true)
  acceptsCard      Boolean  @default(false)
  acceptsWallet    Boolean  @default(false)
  
  // Delivery
  deliveryEnabled  Boolean  @default(true)
  selfDelivery     Boolean  @default(true)
  thirdPartyDelivery Boolean @default(false)
  
  // Loyalty
  loyaltyEnabled   Boolean  @default(true)
  pointsPerAmount  Float    @default(1)
  pointValue       Float    @default(10)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OrganizationUser {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role           String   @default("member")
  permissions    String?
  
  invitedBy      String?
  invitedAt      DateTime?
  acceptedAt     DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([organizationId, userId])
}

// ============================================
// LOOKUP TABLES
// ============================================

model Country {
  id              String   @id @default(cuid())
  code            String   @unique // CI, SN, GH, etc.
  name            String
  phoneCode       String   // +225, +221, etc.
  currencyId      String?
  currency        Currency? @relation(fields: [currencyId], references: [id])
  flagEmoji       String?
  
  isActive        Boolean  @default(true)
  
  organizations   Organization[]
  restaurants     Restaurant[]
  
  @@index([code])
}

model Currency {
  id              String   @id @default(cuid())
  code            String   @unique // XOF, XAF, KES, etc.
  name            String
  symbol          String   // FCFA, KSh, etc.
  decimalPlaces   Int      @default(0)
  
  isActive        Boolean  @default(true)
  
  organizations   Organization[]
  countries       Country[]
  orders          Order[]
  
  @@index([code])
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action       String
  entityType   String
  entityId     String?
  details      String?  // JSON
  
  ipAddress    String?
  userAgent    String?
  
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// Export for seeding
// Note: This is a partial schema for PostgreSQL
// Full schema is in schema.prisma (SQLite version)
// Run: npx prisma db push to sync
