  orders          Order[]
  
  @@unique([organizationId, phone])
}

// ============================================
// STOCK & INVENTORY
// ============================================

model StockMovement {
  id              String   @id @default(cuid())
  organizationId  String
  restaurantId    String?
  
  ingredientId    String
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  
  type            String   // purchase, use, waste, adjust, return
  quantity        Float
  unit            String?
  
  previousQty     Float
  newQty          Float
  
  referenceType   String?  // order, purchase, adjustment
  referenceId     String?
  
  notes           String?
  recordedBy      String?
  
  createdAt       DateTime @default(now())
  
  @@index([ingredientId])
  @@index([organizationId, createdAt])
}

model Supplier {
  id              String   @id @default(cuid())
  organizationId  String
  
  name            String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  
  // Terms
