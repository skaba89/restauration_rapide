  items           PurchaseOrderItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, orderNumber])
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  ingredientId    String?
  itemName        String
  quantity        Float
  unit            String
  unitPrice       Float
  totalPrice      Float
  
  receivedQty     Float?
  
  createdAt       DateTime @default(now())
  
  @@index([purchaseOrderId])
}

// ============================================
// LOCALIZATION
// ============================================

model Country {
  id              String   @id @default(cuid())
  code            String   @unique // CI, FR, US
  name            String
  dialCode        String   // +225
  currencyId      String
  currency        Currency @relation(fields: [currencyId], references: [id])
  
  // Settings
  defaultLanguage String   @default("fr")
  timezone        String   @default("Africa/Abidjan")
  
  // Tax
  taxIncluded     Boolean  @default(true)
  defaultTaxRate  Float    @default(0)
  
  // Features
  mobileMoneyEnabled Boolean @default(true)
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  
  organizations   Organization[]
  restaurants     Restaurant[]
  cities          City[]
  taxRules        TaxRule[]
  paymentProviders PaymentProviderCountry[]
}

model City {
  id              String   @id @default(cuid())
  countryId       String
  country         Country  @relation(fields: [countryId], references: [id])
  
  name            String
  slug            String
  
  // Geo
  latitude        Float?
  longitude       Float?
  
  isActive        Boolean  @default(true)
  
  districts       District[]
  
  @@unique([countryId, slug])
}

model District {
  id              String   @id @default(cuid())
  cityId          String
  city            City     @relation(fields: [cityId], references: [id])
  
  name            String
  slug            String
  
  // Delivery
  deliveryEnabled Boolean  @default(true)
  
  @@unique([cityId, slug])
}

model Currency {
  id              String   @id @default(cuid())
  code            String   @unique // XOF, EUR, USD
  name            String
  symbol          String
  decimalPlaces   Int      @default(0)
  
  isActive        Boolean  @default(true)
  
  countries       Country[]
  organizations   Organization[]
  exchangeRatesFrom ExchangeRate[] @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[] @relation("ToCurrency")
  
  @@index([code])
}

model ExchangeRate {
  id              String   @id @default(cuid())
  fromCurrencyId  String
  fromCurrency    Currency @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  toCurrencyId    String
  toCurrency      Currency @relation("ToCurrency", fields: [toCurrencyId], references: [id])
  
  rate            Float
  
  validFrom       DateTime
  validUntil      DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([fromCurrencyId, toCurrencyId])
}

model TaxRule {
  id              String   @id @default(cuid())
  countryId       String
  country         Country  @relation(fields: [countryId], references: [id])
  
  name            String
  rate            Float
  
  // Application
  applyToDelivery Boolean  @default(false)
  applyToService  Boolean  @default(false)
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
}

model PaymentProvider {
  id              String   @id @default(cuid())
  code            String   @unique // orange_ci, stripe, mpesa_ke
  name            String
  type            String   // mobile_money, card, wallet
  
  config          String?  // JSON
  
  isActive        Boolean  @default(true)
  
  countries       PaymentProviderCountry[]
  
  @@index([code])
}

model PaymentProviderCountry {
  id              String   @id @default(cuid())
  providerId      String
  provider        PaymentProvider @relation(fields: [providerId], references: [id])
  countryId       String
  country         Country  @relation(fields: [countryId], references: [id])
  
  // Config
  merchantId      String?
  apiKey          String?
  webhookSecret   String?
  
  fees            Float    @default(0)
  feeType         String   @default("percentage") // percentage, fixed
  
  isActive        Boolean  @default(true)
  
  @@unique([providerId, countryId])
}

model Translation {
  id              String   @id @default(cuid())
  key             String
  language        String
  value           String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([key, language])
}

// ============================================
// SETTINGS & CONFIG
// ============================================

model Setting {
  id              String   @id @default(cuid())
  organizationId  String?
  
  key             String
  value           String   // JSON
  description     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, key])
}

model FeatureFlag {
  id              String   @id @default(cuid())
  key             String   @unique
  name            String
  description     String?
  
  enabled         Boolean  @default(false)
  rolloutPercent  Int      @default(0)
  
  // Targeting
  countries       String?  // JSON array
  plans           String?  // JSON array
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// AUDIT & LOGS
// ============================================

model AuditLog {
  id              String   @id @default(cuid())
  organizationId  String?
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action          String   // create, update, delete, login, etc.
  entity          String   // order, customer, restaurant
  entityId        String?
  
  oldValue        String?  // JSON
  newValue        String?  // JSON
  
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime @default(now())
  
  @@index([organizationId, entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// SYNC & OFFLINE
// ============================================

model SyncQueue {
  id              String   @id @default(cuid())
  organizationId  String
  
  entity          String
  entityId        String
  action          String   // create, update, delete
  
  data            String   // JSON
  
  status          String   @default("pending") // pending, syncing, synced, failed
  attempts        Int      @default(0)
  lastAttemptAt   DateTime?
  error           String?
  
  createdAt       DateTime @default(now())
  syncedAt        DateTime?
  
  @@index([organizationId, status])
  @@index([entity, entityId])
}

model DeviceState {
  id              String   @id @default(cuid())
  deviceId        String   @unique
  userId          String?
  
  lastSyncAt      DateTime?
  syncVersion     Int      @default(0)
  
  pendingUploads  Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id              String   @id @default(cuid())
  userId          String
  
  title           String
  message         String
  type            String   // order, delivery, promotion, system
  
  data            String?  // JSON
  
  read            Boolean  @default(false)
  readAt          DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([userId, read])
}

// ============================================
// ANALYTICS
// ============================================

model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  organizationId  String
  restaurantId    String?
  
  date            DateTime
  
  // Orders
  orderCount      Int      @default(0)
  orderTotal      Float    @default(0)
  avgOrderValue   Float    @default(0)
  
  // By Type
  dineInCount     Int      @default(0)
  dineInTotal     Float    @default(0)
  takeawayCount   Int      @default(0)
  takeawayTotal   Float    @default(0)
  deliveryCount   Int      @default(0)
  deliveryTotal   Float    @default(0)
  
  // Customers
  newCustomers    Int      @default(0)
  returningCustomers Int   @default(0)
  
  // Reservations
  reservationCount Int     @default(0)
  noShowCount     Int      @default(0)
  
  // Delivery
  avgDeliveryTime Int?
  deliverySuccessRate Float?
  
  // Payments
  cashTotal       Float    @default(0)
  mobileMoneyTotal Float  @default(0)
  cardTotal       Float    @default(0)
  
  // Products
  topProducts     String?  // JSON
  topCategories   String?  // JSON
  
  createdAt       DateTime @default(now())
  
  @@unique([organizationId, restaurantId, date])
  @@index([organizationId, date])
}

// ============================================
// PUSH SUBSCRIPTIONS
// ============================================

model PushSubscription {
  id              String   @id @default(cuid())
  userId          String
  
  endpoint        String   @unique
  p256dh          String
  auth            String
  
  userAgent       String?
  deviceId        String?
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([endpoint])
}
