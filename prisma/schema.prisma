// ============================================
// RESTAURANT OS - Complete Database Schema
// Africa-First, Global-Ready
// ============================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE - Users & Authentication
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  role          UserRole  @default(CUSTOMER)
  
  // Profile
  firstName     String?
  lastName      String?
  avatar        String?
  language      String    @default("fr")
  timezone      String    @default("Africa/Abidjan")
  
  // Verification
  emailVerified DateTime?
  phoneVerified DateTime?
  
  // Status
  isActive      Boolean   @default(true)
  isLocked      Boolean   @default(false)
  lockedAt      DateTime?
  lastLoginAt   DateTime?
  lastLoginIp   String?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  // Relations
  sessions      Session[]
  otpCodes      OtpCode[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  organizationUsers OrganizationUser[]
  
  // Polymorphic relations
  customerProfiles  CustomerProfile[]
  staffProfiles     StaffProfile[]
  driverProfile     Driver?
  
  @@index([email])
  @@index([phone])
  @@index([role])
}

enum UserRole {
  SUPER_ADMIN      // Platform admin
  ORG_ADMIN        // Organization owner
  ORG_MANAGER      // Organization manager
  RESTAURANT_ADMIN // Restaurant admin
  RESTAURANT_MANAGER
  STAFF            // Waiter, host, etc.
  KITCHEN
  DRIVER
  CUSTOMER
  SUPPORT
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

model OtpCode {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone        String?
  email        String?
  code         String
  type         OtpType
  attempts     Int      @default(0)
  
  verifiedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([phone, type])
  @@index([email, type])
}

enum OtpType {
  LOGIN
  REGISTER
  VERIFY_PHONE
  VERIFY_EMAIL
  RESET_PASSWORD
  VERIFY_PAYMENT
}

// ============================================
// ORGANIZATION - Multi-tenant
// ============================================

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logo            String?
  description     String?
  website         String?
  
  // Contact
  email           String
  phone           String
  address         String?
  city            String
  countryId       String
  country         Country  @relation(fields: [countryId], references: [id])
  
  // Business
  taxId           String?
  businessType    String?
  currencyId      String
  currency        Currency @relation(fields: [currencyId], references: [id])
  
  // Subscription
  plan            Plan     @default(STARTER)
  planExpiresAt   DateTime?
  stripeCustomerId String?
  
  // Settings
  settings        OrganizationSettings?
  isActive        Boolean  @default(true)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  users           OrganizationUser[]
  brands          Brand[]
  restaurants     Restaurant[]
  
  @@index([slug])
  @@index([countryId])
}

enum Plan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

model OrganizationSettings {
  id               String   @id @default(cuid())
  organizationId   String   @unique
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Orders
  minOrderAmount   Float    @default(0)
  maxDeliveryRadius Float   @default(10)
  defaultDeliveryFee Float  @default(0)
  autoAcceptOrders Boolean  @default(false)
  orderPrepTime    Int      @default(15) // minutes
  
  // Reservations
  reservationEnabled Boolean @default(true)
  autoConfirmReservations Boolean @default(true)
  defaultTableTime Int      @default(120) // minutes
  noShowFee        Float    @default(0)
  noShowBuffer     Int      @default(15) // minutes grace period
  
  // Payments
  acceptsCash      Boolean  @default(true)
  acceptsMobileMoney Boolean @default(true)
  acceptsCard      Boolean  @default(false)
  acceptsWallet    Boolean  @default(false)
  
  // Delivery
  deliveryEnabled  Boolean  @default(true)
  selfDelivery     Boolean  @default(true)
  thirdPartyDelivery Boolean @default(false)
  
  // Loyalty
  loyaltyEnabled   Boolean  @default(true)
  pointsPerAmount  Float    @default(1) // points per 1000 currency
  pointValue       Float    @default(10) // currency per point
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OrganizationUser {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role           String   @default("member") // admin, manager, member
  permissions    String?  // JSON array of permissions
  
  invitedBy      String?
  invitedAt      DateTime?
  acceptedAt     DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([organizationId, userId])
}

model Brand {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name           String
  slug           String
  logo           String?
  description    String?
  website        String?
  colors         String?  // JSON {primary, secondary, accent}
  isActive       Boolean  @default(true)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  restaurants    Restaurant[]
  
  @@unique([organizationId, slug])
}

// ============================================
// RESTAURANT
// ============================================

model Restaurant {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandId         String?
  brand           Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  
  // Basic Info
  name            String
  slug            String
  description     String?
  coverImage      String?
  logo            String?
  
  // Contact
  email           String?
  phone           String
  website         String?
  
  // Location
  address         String
  address2        String?
  city            String
  district        String?  // Quartier
  landmark        String?  // Point de repère
  postalCode      String?
  countryId       String
  country         Country  @relation(fields: [countryId], references: [id])
  
  // Geo
  latitude        Float?
  longitude       Float?
  geoPrecision    Int?     // meters accuracy
  geoSource       String?  // gps, manual, estimated
  
  // Type & Features
  restaurantType  String   @default("restaurant") // restaurant, cafe, bar, hotel, dark_kitchen
  cuisines        String?  // JSON array
  priceRange      Int      @default(2) // 1-4 ($ - $$$$)
  
  // Capacity
  indoorCapacity  Int?
  outdoorCapacity Int?
  totalCapacity   Int?
  
  // Features
  acceptsReservations Boolean @default(true)
  acceptsWalkins  Boolean  @default(true)
  acceptsDelivery Boolean  @default(true)
  acceptsTakeaway Boolean  @default(true)
  acceptsDineIn   Boolean  @default(true)
  hasParking      Boolean  @default(false)
  hasWifi         Boolean  @default(true)
  hasTerrace      Boolean  @default(false)
  hasVipRoom      Boolean  @default(false)
  
  // Delivery Settings
  deliveryZones   DeliveryZone[]
  deliveryFee     Float    @default(0)
  minOrderAmount  Float    @default(0)
  maxDeliveryRadius Float  @default(10)
  deliveryTime    Int      @default(30) // estimated minutes
  
  // Payment
  paymentMethods  String?  // JSON array
  
  // Rating
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  
  // Status
  isActive        Boolean  @default(true)
  isOpen          Boolean  @default(false)
  isBusy          Boolean  @default(false)
  
  // Settings override
  settings        RestaurantSettings?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  hours           RestaurantHour[]
  specialHours    RestaurantSpecialHour[]
  tables          Table[]
  diningRooms     DiningRoom[]
  staffProfiles   StaffProfile[]
  menus           Menu[]
  orders          Order[]
  reservations    Reservation[]
  waitlist        WaitlistEntry[]
  reviews         Review[]
  
  @@unique([organizationId, slug])
  @@index([countryId, city])
  @@index([isActive])
}

model RestaurantSettings {
  id              String   @id @default(cuid())
  restaurantId    String   @unique
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  // Override org settings
  minOrderAmount  Float?
  deliveryFee     Float?
  orderPrepTime   Int?
  
  // Reservation
  reservationSettings String? // JSON
  tableTime       Int?
  noShowFee       Float?
  
  // Loyalty
  loyaltyEnabled  Boolean?
  
  // Notifications
  notificationSettings String? // JSON
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RestaurantHour {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  dayOfWeek       Int      // 0=Sunday, 6=Saturday
  openTime        String?  // HH:mm
  closeTime       String?  // HH:mm
  isClosed        Boolean  @default(false)
  
  // Break
  breakStart      String?
  breakEnd        String?
  
  // Kitchen
  kitchenOpen     String?
  kitchenClose    String?
  lastSeating     String?
  
  @@unique([restaurantId, dayOfWeek])
}

model RestaurantSpecialHour {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  date            DateTime
  name            String?  // Holiday name
  openTime        String?
  closeTime       String?
  isClosed        Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  
  @@unique([restaurantId, date])
}

// ============================================
// DINING - Tables & Rooms
// ============================================

model DiningRoom {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  name            String
  type           String   @default("indoor") // indoor, outdoor, terrace, vip, private
  capacity        Int
  floorPlan       String?  // JSON layout
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  tables          Table[]
  
  @@unique([restaurantId, name])
}

model Table {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  diningRoomId    String?
  diningRoom      DiningRoom? @relation(fields: [diningRoomId], references: [id], onDelete: SetNull)
  
  number          String   // Table number/name
  capacity        Int      @default(4)
  shape           String   @default("round") // round, square, rectangle
  positionX       Float?
  positionY       Float?
  width           Float?
  height          Float?
  rotation        Float?
  
  status          TableStatus @default(AVAILABLE)
  currentPartySize Int?
  currentReservationId String?
  serverId        String?
  server          StaffProfile? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  
  // Features
  isAccessible    Boolean  @default(false)
  isVip           Boolean  @default(false)
  isCombineable   Boolean  @default(true)
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  reservations    ReservationTable[]
  qrSessions      QrSession[]
  
  @@unique([restaurantId, number])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DIRTY
  OUT_OF_SERVICE
}

// ============================================
// MENU
// ============================================

model Menu {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String
  description     String?
  isActive        Boolean  @default(true)
  
  // Availability
  availableDays   String?  // JSON array [0,1,2,3,4,5,6]
  availableStart  String?  // HH:mm
  availableEnd    String?  // HH:mm
  
  // Type
  menuType        String   @default("main") // main, brunch, happy_hour, special, catering
  
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  categories      MenuCategory[]
  
  @@unique([restaurantId, slug])
}

model MenuCategory {
  id              String   @id @default(cuid())
  menuId          String
  menu            Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String
  description     String?
  image           String?
  icon            String?
  
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           MenuItem[]
  
  @@unique([menuId, slug])
}

model MenuItem {
  id              String   @id @default(cuid())
  categoryId      String
  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  name            String
  slug            String
  description     String?
  image           String?
  images          String?  // JSON array
  
  // Pricing
  price           Float
  discountPrice   Float?
  costPrice       Float?
  currencyId      String?
  
  // Nutrition
  calories        Int?
  protein         Float?
  carbs           Float?
  fat             Float?
  fiber           Float?
  sodium          Float?
  
  // Time
  prepTime        Int?     // minutes
  
  // Availability
  isAvailable     Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  isPopular       Boolean  @default(false)
  isNew           Boolean  @default(false)
  
  // Type
  itemType        String   @default("food") // food, drink, dessert, side, addon
  
  // Flags
  isVegetarian    Boolean  @default(false)
  isVegan         Boolean  @default(false)
  isHalal         Boolean  @default(false)
  isGlutenFree    Boolean  @default(false)
  isSpicy         Boolean  @default(false)
  spicyLevel      Int      @default(0) // 0-3
  
  // Inventory
  trackInventory  Boolean  @default(false)
  quantity        Int      @default(0)
  lowStockThreshold Int    @default(5)
  
  // Sort
  sortOrder       Int      @default(0)
  
  // Stats
  orderCount      Int      @default(0)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  variants        MenuItemVariant[]
  options         MenuItemOption[]
  allergens       MenuItemAllergen[]
  ingredients     MenuItemIngredient[]
  orderItems      OrderItem[]
  cartItems       CartItem[]
  
  @@unique([categoryId, slug])
  @@index([isAvailable, isFeatured])
}

model MenuItemVariant {
  id              String   @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  
  name            String   // Small, Medium, Large
  price           Float
  isDefault       Boolean  @default(false)
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  
  @@index([menuItemId])
}

model MenuItemOption {
  id              String   @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  
  name            String   // Extra cheese, Sauce
  required        Boolean  @default(false)
  multiSelect     Boolean  @default(false)
  maxSelect       Int?
  sortOrder       Int      @default(0)
  
  values          MenuItemOptionValue[]
  
  @@index([menuItemId])
}

model MenuItemOptionValue {
  id              String   @id @default(cuid())
  optionId        String
  option          MenuItemOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  name            String
  price           Float    @default(0)
  isDefault       Boolean  @default(false)
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
}

model MenuItemAllergen {
  id              String   @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  allergenId      String
  allergen        Allergen @relation(fields: [allergenId], references: [id])
  
  @@unique([menuItemId, allergenId])
}

model Allergen {
  id              String   @id @default(cuid())
  name            String
  icon            String?
  description     String?
  
  menuItems       MenuItemAllergen[]
}

model MenuItemIngredient {
  id              String   @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  quantity        Float?
  unit            String?
  
  @@unique([menuItemId, ingredientId])
}

model Ingredient {
  id              String   @id @default(cuid())
  organizationId  String
  
  name            String
  unit            String   // kg, g, l, ml, piece
  costPerUnit     Float?
  
  quantity        Float    @default(0)
  lowStockThreshold Float  @default(0)
  
  menuItems       MenuItemIngredient[]
  stockMovements  StockMovement[]
  
  @@index([organizationId])
}

// ============================================
// RESERVATIONS & WAITLIST
// ============================================

model Reservation {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  // Customer
  customerId      String?
  customer        CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestName       String
  guestPhone      String
  guestEmail      String?
  
  // Details
  partySize       Int
  date            DateTime
  time            String   // HH:mm
  duration        Int      @default(120) // minutes
  
  // Tables
  tables          ReservationTable[]
  
  // Status
  status          ReservationStatus @default(PENDING)
  source          String   @default("web") // web, phone, walkin, app
  
  // Special
  occasion        String?  // birthday, anniversary, business, date
  specialRequests String?
  dietaryNotes    String?
  internalNotes   String?
  
  // Deposit
  depositAmount   Float?
  depositPaid     Boolean  @default(false)
  depositRefundable Boolean @default(true)
  
  // Confirmation
  confirmedAt     DateTime?
  confirmedBy     String?
  reminderSentAt  DateTime?
  
  // Check-in/out
  checkedInAt     DateTime?
  seatedAt        DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  
  // No-show
  noShowAt        DateTime?
  noShowCharged   Boolean  @default(false)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([restaurantId, date])
  @@index([restaurantId, status])
  @@index([customerId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model ReservationTable {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tableId         String
  table           Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  
  @@unique([reservationId, tableId])
}

model WaitlistEntry {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  // Customer
  customerId      String?
  customer        CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestName       String
  guestPhone      String
  partySize       Int
  
  // Preferences
  preferredArea   String?
  specialRequests String?
  
  // Status
  status          WaitlistStatus @default(WAITING)
  priority        Int      @default(0) // higher = more priority
  
  // Timing
  estimatedWait   Int?     // minutes
  quotedWait      Int?     // minutes told to customer
  notifiedAt      DateTime?
  seatedAt        DateTime?
  cancelledAt     DateTime?
  expiredAt       DateTime?
  
  // Conversion
  convertedToReservationId String?
  
  // Notes
  internalNotes   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([restaurantId, status])
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  SEATED
  CANCELLED
  EXPIRED
  CONVERTED
}

// ============================================
// ORDERS
// ============================================

model Order {
  id              String   @id @default(cuid())
  orderNumber     String
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  // Customer
  customerId      String?
  customer        CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String
  customerPhone   String
  customerEmail   String?
  
  // Type & Source
  orderType       OrderType @default(DINE_IN)
  source          String   @default("web") // web, app, pos, phone, qr
  channelId       String?  // For multi-channel tracking
  
  // Status
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  
  // Table (for dine-in)
  tableId         String?
  tableNumber     String?
  
  // Delivery
  deliveryAddress String?
  deliveryCity    String?
  deliveryDistrict String?
  deliveryLandmark String?
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryNotes   String?
  deliveryZoneId  String?
  deliveryFee     Float    @default(0)
  deliveryTime    Int?     // estimated minutes
  
  // Scheduled
  scheduledAt     DateTime?
  asap            Boolean  @default(true)
  
  // Pricing
  subtotal        Float
  discount        Float    @default(0)
  discountCode    String?
  tax             Float    @default(0)
  serviceCharge   Float    @default(0)
  tip             Float    @default(0)
  total           Float
  currencyId      String
  
  // Loyalty
  loyaltyPointsEarned Int  @default(0)
  loyaltyPointsUsed Int   @default(0)
  
  // Notes
  notes           String?
  internalNotes   String?
  
  // Staff
  serverId        String?
  server          StaffProfile? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  createdById     String?
  
  // Timestamps
  confirmedAt     DateTime?
  preparingAt     DateTime?
  readyAt         DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  items           OrderItem[]
  payments        Payment[]
  delivery        Delivery?
  statusHistory   OrderStatusHistory[]
  
  // QR Session
  qrSessionId     String?
  qrSession       QrSession? @relation(fields: [qrSessionId], references: [id], onDelete: SetNull)
  
  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, status])
  @@index([restaurantId, createdAt])
  @@index([customerId])
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  DRIVE_THRU
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  menuItemId      String?
  menuItem        MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  
  // Snapshot
  itemName        String
  itemImage       String?
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  
  // Variant
  variantId       String?
  variantName     String?
  
  // Options
  options         String?  // JSON
  
  // Status
  status          String   @default("pending") // pending, preparing, ready, served
  
  // Notes
  notes           String?
  
  // Kitchen
  startedAt       DateTime?
  completedAt     DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([orderId])
  @@index([menuItemId])
}

model OrderStatusHistory {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  status          String
  notes           String?
  changedBy       String?
  
  createdAt       DateTime @default(now())
  
  @@index([orderId])
}

// ============================================
// CART
// ============================================

model Cart {
  id              String   @id @default(cuid())
  restaurantId    String
  customerId      String?
  customer        CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  sessionId       String?
  
  // Delivery
  deliveryAddress String?
  deliveryCity    String?
  deliveryDistrict String?
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryNotes   String?
  
  // Scheduled
  scheduledAt     DateTime?
  asap            Boolean  @default(true)
  
  // Totals
  subtotal        Float    @default(0)
  discount        Float    @default(0)
  tax             Float    @default(0)
  deliveryFee     Float    @default(0)
  tip             Float    @default(0)
  total           Float    @default(0)
  
  // Promo
  promoCode       String?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  expiresAt       DateTime?
  
  items           CartItem[]
  
  @@index([sessionId])
  @@index([customerId])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  menuItemId      String
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  
  variantId       String?
  options         String?  // JSON
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([cartId])
}

// ============================================
// QR SESSIONS (Table QR Ordering)
// ============================================

model QrSession {
  id              String   @id @default(cuid())
  restaurantId    String
  tableId         String?
  table           Table?   @relation(fields: [tableId], references: [id], onDelete: SetNull)
  
  code            String   @unique
  isActive        Boolean  @default(true)
  
  customerId      String?
  customer        CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  
  orders          Order[]
  
  @@index([code])
  @@index([restaurantId, isActive])
}

// ============================================
// DELIVERY
// ============================================

model DeliveryZone {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Coverage
  districts       String?  // JSON array of district names
  polygon         String?  // GeoJSON polygon
  
  // Pricing
  baseFee         Float    @default(0)
  perKmFee        Float    @default(0)
  minOrder        Float    @default(0)
  
  // Timing
  minTime         Int      @default(15) // minutes
  maxTime         Int      @default(45) // minutes
  
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([restaurantId, name])
}

model Delivery {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organizationId  String
  
  // Pickup
  pickupAddress   String
  pickupLat       Float?
  pickupLng       Float?
  pickupNotes     String?
  
  // Dropoff
  dropoffAddress  String
  dropoffLat      Float?
  dropoffLng      Float?
  dropoffNotes    String?
  dropoffLandmark String?
  
  // Driver
  driverId        String?
  driver          Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  
  // Status
  status          DeliveryStatus @default(PENDING)
  dispatchType    String   @default("auto") // auto, manual
  
  // Fees
  deliveryFee     Float
  driverEarning   Float
  tip             Float    @default(0)
  
  // Timing
  estimatedTime   Int?     // minutes
  actualTime      Int?     // minutes
  distance        Float?   // km
  
  assignedAt      DateTime?
  driverArrivedAt DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  
  // Proof
  proofType       String?  // otp, photo, signature
  proofOtp        String?
  proofPhotoUrl   String?
  proofSignature  String?
  proofLat        Float?
  proofLng        Float?
  
  // Issue
  failureReason   String?
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  trackingEvents  DeliveryTrackingEvent[]
  
  @@index([driverId, status])
  @@index([organizationId, status])
}

enum DeliveryStatus {
  PENDING
  SEARCHING_DRIVER
  DRIVER_ASSIGNED
  DRIVER_ARRIVED_PICKUP
  PICKED_UP
  DRIVER_ARRIVED_DROPOFF
  DELIVERED
  FAILED
  CANCELLED
  RETURNED
}

model DeliveryTrackingEvent {
  id              String   @id @default(cuid())
  deliveryId      String
  delivery        Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  
  event           String
  lat             Float?
  lng             Float?
  notes           String?
  
  createdAt       DateTime @default(now())
  
  @@index([deliveryId])
}

// ============================================
// DRIVERS
// ============================================

model Driver {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Profile
  firstName       String
  lastName        String
  phone           String
  email           String?
  avatar          String?
  dateOfBirth     String?
  
  // Vehicle
  vehicleType     String   @default("motorcycle") // motorcycle, bicycle, car, scooter
  vehicleBrand    String?
  vehicleModel    String?
  vehiclePlate    String?
  vehicleColor    String?
  
  // Documents
  idType          String?
  idNumber        String?
  idFrontImage    String?
  idBackImage     String?
  licenseNumber   String?
  licenseImage    String?
  insuranceNumber String?
  insuranceImage  String?
  
  // Verification
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?
  
  // Status
  isActive        Boolean  @default(true)
  isAvailable     Boolean  @default(false)
  status          String   @default("offline") // online, offline, busy, suspended
  
  // Location
  currentLat      Float?
  currentLng      Float?
  currentAccuracy Float?
  lastLocationAt  DateTime?
  currentZone     String?
  
  // Stats
  totalDeliveries Int      @default(0)
  totalEarnings   Float    @default(0)
  totalDistance   Float    @default(0)
  rating          Float    @default(5.0)
  reviewCount     Int      @default(0)
  
  // Bank
  bankName        String?
  bankAccount     String?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  deliveries      Delivery[]
  earnings        DriverEarning[]
  wallet          DriverWallet?
  sessions        DriverSession[]
  documents       DriverDocument[]
  
  @@unique([organizationId, phone])
  @@index([organizationId, isActive])
  @@index([organizationId, isAvailable])
}

model DriverSession {
  id              String   @id @default(cuid())
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  // Session
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  
  // Stats for session
  deliveries      Int      @default(0)
  earnings        Float    @default(0)
  distance        Float    @default(0)
  
  // Location tracking
  locations       DriverLocation[]
  
  @@index([driverId, startedAt])
}

model DriverLocation {
  id              String   @id @default(cuid())
  sessionId       String
  session         DriverSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  lat             Float
  lng             Float
  accuracy        Float?
  speed           Float?
  bearing         Float?
  
  batteryLevel    Int?
  isOnline        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  
  @@index([sessionId, createdAt])
}

model DriverEarning {
  id              String   @id @default(cuid())
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  deliveryId      String?
  type            String   // delivery_fee, tip, bonus, adjustment
  
  amount          Float
  description     String?
  
  createdAt       DateTime @default(now())
  
  @@index([driverId])
}

model DriverWallet {
  id              String   @id @default(cuid())
  driverId        String   @unique
  driver          Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  balance         Float    @default(0)
  pending         Float    @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  transactions    DriverWalletTransaction[]
}

model DriverWalletTransaction {
  id              String   @id @default(cuid())
  walletId        String
  wallet          DriverWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  type            String   // credit, debit, payout, adjustment
  amount          Float
  balance         Float    // balance after transaction
  
  referenceType   String?  // delivery, payout, bonus
  referenceId     String?
  description     String?
  
  createdAt       DateTime @default(now())
  
  @@index([walletId])
}

model DriverDocument {
  id              String   @id @default(cuid())
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  type            String   // id_card, license, insurance, vehicle_registration
  documentNumber  String?
  imageUrl        String?
  
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  expiresAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([driverId, type])
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Amount
  amount          Float
  currencyId      String
  
  // Method
  method          PaymentMethod
  provider        String?  // orange, mtn, wave, stripe, etc.
  
  // Status
  status          PaymentStatus @default(PENDING)
  
  // Mobile Money
  phoneNumber     String?
  providerRef     String?
  transactionId   String?
  
  // Card
  cardLastFour    String?
  cardBrand       String?
  
  // Cash
  collectedBy     String?
  collectedAt     DateTime?
  
  // Processing
  processedAt     DateTime?
  failedAt        DateTime?
  failureReason   String?
  
  // Refund
  refundedAt      DateTime?
  refundAmount    Float?
  refundReason    String?
  
  // Metadata
  metadata        String?  // JSON
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([orderId])
  @@index([method, status])
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY_ORANGE
  MOBILE_MONEY_MTN
  MOBILE_MONEY_WAVE
  MOBILE_MONEY_MPESA
  MOBILE_MONEY_MOOV
  CARD
  WALLET
  BANK_TRANSFER
  APPLE_PAY
  GOOGLE_PAY
  GIFT_CARD
}

// ============================================
// CUSTOMERS & CRM
// ============================================

model CustomerProfile {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  organizationId  String
  
  // Profile
  firstName       String?
  lastName        String?
  phone           String
  email           String?
  avatar          String?
  dateOfBirth     String?
  
  // Preferences
  language        String   @default("fr")
  currency        String   @default("XOF")
  notifications   String?  // JSON
  
  // Addresses
  addresses       String?  // JSON array
  
  // Dietary
  dietaryPreferences String? // JSON
  allergies       String?  // JSON array
  
  // Stats
  totalOrders     Int      @default(0)
  totalSpent      Float    @default(0)
  avgOrderValue   Float    @default(0)
  lastOrderAt     DateTime?
  
  // Loyalty
  loyaltyPoints   Int      @default(0)
  loyaltyLevel    Int      @default(1)
  lifetimePoints  Int      @default(0)
  
  // Segmentation
  tags            String?  // JSON array
  segment         String?
  
  // VIP
  isVip           Boolean  @default(false)
  vipSince        DateTime?
  
  // Notes
  notes           String?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  orders          Order[]
  reservations    Reservation[]
  waitlist        WaitlistEntry[]
  loyaltyTransactions LoyaltyTransaction[]
  carts           Cart[]
  qrSessions      QrSession[]
  reviews         Review[]
  feedback        CustomerFeedback[]
  
  @@unique([organizationId, phone])
  @@index([organizationId])
}

model CustomerTag {
  id              String   @id @default(cuid())
  organizationId  String
  
  name            String
  color           String?
  description     String?
  
  createdAt       DateTime @default(now())
  
  @@unique([organizationId, name])
}

model CustomerFeedback {
  id              String   @id @default(cuid())
  organizationId  String
  restaurantId    String?
  customerId      String?
  customer        CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderId         String?
  
  type            String   // complaint, compliment, suggestion
  category        String?
  subject         String?
  message         String
  rating          Int?
  
  status          String   @default("new") // new, in_progress, resolved
  response        String?
  respondedAt     DateTime?
  respondedBy     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([organizationId, status])
}

// ============================================
// LOYALTY
// ============================================

model LoyaltyTransaction {
  id              String   @id @default(cuid())
  organizationId  String
  customerId      String
  customer        CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  points          Int      // positive = earn, negative = redeem
  type            String   // earn, redeem, bonus, expire, adjust
  
  description     String?
  referenceType   String?  // order, reward, referral
  referenceId     String?
  
  balanceAfter    Int
  
  expiresAt       DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([customerId])
  @@index([organizationId])
}

model LoyaltyReward {
  id              String   @id @default(cuid())
  organizationId  String
  
  name            String
  description     String?
  image           String?
  
  pointsRequired  Int
  
  // Reward type
  type            String   // discount, free_item, cashback
  value           Float    // discount % or cashback amount
  productId       String?
  
  isActive        Boolean  @default(true)
  
  validFrom       DateTime?
  validUntil      DateTime?
  
  usageLimit      Int?
  usageCount      Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([organizationId, isActive])
}

model LoyaltyLevel {
  id              String   @id @default(cuid())
  organizationId  String
  
  level           Int
  name            String   // Bronze, Silver, Gold, Platinum
  minPoints       Int
  
  // Benefits
  discountPercent Float?
  freeDelivery    Boolean  @default(false)
  prioritySupport Boolean  @default(false)
  pointsMultiplier Float  @default(1)
  
  color           String?
  icon            String?
  
  createdAt       DateTime @default(now())
  
  @@unique([organizationId, level])
}

// ============================================
// PROMOTIONS & MARKETING
// ============================================

model Promotion {
  id              String   @id @default(cuid())
  organizationId  String
  restaurantId    String?
  
  name            String
  code            String?  @unique
  description     String?
  image           String?
  
  // Type
  type            String   // percentage, fixed, free_delivery, bogo
  value           Float
  
  // Conditions
  minOrderAmount  Float?
  maxDiscount     Float?
  applicableItems String?  // JSON array of product IDs
  
  // Usage
  usageLimit      Int?
  usageCount      Int      @default(0)
  perUserLimit    Int?
  
  // Validity
  validFrom       DateTime
  validUntil      DateTime?
  
  isActive        Boolean  @default(true)
  
  // Targeting
  targetSegments  String?  // JSON array
  targetNewUsers  Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([organizationId, isActive])
}

model GiftCard {
  id              String   @id @default(cuid())
  organizationId  String
  
  code            String   @unique
  pin             String?
  
  initialBalance  Float
  balance         Float
  currencyId      String
  
  purchaserId     String?
  recipientEmail  String?
  recipientName   String?
  message         String?
  
  status          String   @default("active") // active, used, expired, cancelled
  
  expiresAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  transactions    GiftCardTransaction[]
  
  @@index([code])
}

model GiftCardTransaction {
  id              String   @id @default(cuid())
  giftCardId      String
  giftCard        GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  
  type            String   // purchase, redeem, refund, expire
  amount          Float
  balanceAfter    Float
  
  orderId         String?
  
  createdAt       DateTime @default(now())
  
  @@index([giftCardId])
}

model Campaign {
  id              String   @id @default(cuid())
  organizationId  String
  
  name            String
  description     String?
  type            String   // email, sms, push, whatsapp
  
  // Content
  subject         String?
  content         String?
  templateId      String?
  
  // Targeting
  targetSegments  String?  // JSON
  targetAll       Boolean  @default(false)
  
  // Schedule
  scheduledAt     DateTime?
  sentAt          DateTime?
  
  // Stats
  totalSent       Int      @default(0)
  totalOpened     Int      @default(0)
  totalClicked    Int      @default(0)
  
  status          String   @default("draft") // draft, scheduled, sending, sent, cancelled
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([organizationId, status])
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  customerId      String?
  customer        CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  orderId         String?
  
  rating          Int      // 1-5
  foodRating      Int?
  serviceRating   Int?
  ambianceRating  Int?
  valueRating     Int?
  
  title           String?
  comment         String?
  images          String?  // JSON array
  
  // Response
  response        String?
  respondedAt     DateTime?
  respondedBy     String?
  
  // Status
  isVerified      Boolean  @default(false)
  isPublished     Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([restaurantId, createdAt])
  @@index([customerId])
}

// ============================================
// STAFF
// ============================================

model StaffProfile {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  organizationId  String
  restaurantId    String?
  restaurant      Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  
  // Profile
  firstName       String
  lastName        String
  phone           String
  email           String?
  avatar          String?
  
  // Role
  role            String   // waiter, host, bartender, chef, manager
  permissions     String?  // JSON
  
  // Status
  isActive        Boolean  @default(true)
  
  // Schedule
  defaultSchedule String?  // JSON
  
  // Stats
  ordersHandled   Int      @default(0)
  tablesServed    Int      @default(0)
  rating          Float    @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
