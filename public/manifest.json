{
  "name": "Restaurant OS - Gestion de Restaurant",
  "short_name": "Restaurant OS",
  "description": "Système de gestion de restaurant multi-devises, multi-pays, avec support mobile money et livraison moto. Africa-First, Global-Ready.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#f97316",
  "orientation": "any",
  "scope": "/",
  "lang": "fr",
  "categories": ["business", "food", "productivity"],
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/dashboard.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Dashboard Principal"
    },
    {
      "src": "/screenshots/orders.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Gestion des Commandes"
    }
  ],
  "shortcuts": [
    {
      "name": "Nouvelle Commande",
      "short_name": "Commande",
      "description": "Créer une nouvelle commande",
      "url": "/orders?action=new",
      "icons": [{ "src": "/icons/order-icon.png", "sizes": "96x96" }]
    },
    {
      "name": "Tableau de Bord",
      "short_name": "Dashboard",
      "description": "Voir le tableau de bord",
      "url": "/dashboard",
      "icons": [{ "src": "/icons/dashboard-icon.png", "sizes": "96x96" }]
    },
    {
      "name": "Menu",
      "short_name": "Menu",
      "description": "Gérer le menu",
      "url": "/menu",
      "icons": [{ "src": "/icons/menu-icon.png", "sizes": "96x96" }]
    },
    {
      "name": "Livraisons",
      "short_name": "Livraisons",
      "description": "Voir les livraisons en cours",
      "url": "/deliveries",
      "icons": [{ "src": "/icons/delivery-icon.png", "sizes": "96x96" }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "share_target": {
    "action": "/orders/new",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "image",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+restaurantos",
      "url": "/orders?id=%s"
    }
  ]
}
